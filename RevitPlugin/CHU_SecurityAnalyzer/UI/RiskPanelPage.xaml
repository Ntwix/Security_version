<Page
    x:Class="CHU_SecurityAnalyzer.UI.RiskPanelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#1E1E2E">

    <Page.Resources>
        <!-- Style niveau (header) -->
        <Style x:Key="LevelHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Margin" Value="2,4,0,2"/>
        </Style>
        <!-- Style local -->
        <Style x:Key="SpaceItemStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#BAC2DE"/>
            <Setter Property="Margin" Value="16,1,0,1"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <!-- Style bouton filtre -->
        <Style x:Key="FilterBtnStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="2,2,2,2"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#89B4FA"/>
                    <Setter Property="Foreground" Value="#1E1E2E"/>
                    <Setter Property="BorderBrush" Value="#89B4FA"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45475A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header titre + compteur -->
        <Border Grid.Row="0" Background="#181825" Padding="8,6">
            <StackPanel>
                <TextBlock Text="CHU Sécurité - Zones à Risque"
                           FontWeight="Bold" FontSize="13"
                           Foreground="#CDD6F4"/>
                <TextBlock x:Name="TxtSummary"
                           Text="Aucune analyse"
                           FontSize="11" Foreground="#6C7086"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Séparateur -->
        <Separator Grid.Row="1" Background="#313244" Margin="0"/>

        <!-- Boutons de filtre -->
        <Border Grid.Row="2" Background="#181825" Padding="6,4">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="Filtre :" Foreground="#6C7086"
                           FontSize="11" VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <ToggleButton x:Name="BtnAll" Content="Tout"
                              Style="{StaticResource FilterBtnStyle}"
                              IsChecked="True"
                              Checked="BtnAll_Checked"/>
                <ToggleButton x:Name="BtnElec002" Content="ELEC-002"
                              Style="{StaticResource FilterBtnStyle}"
                              Tag="ELEC-002"
                              Foreground="#89B4FA" BorderBrush="#89B4FA"
                              Checked="BtnRule_Checked"
                              Unchecked="BtnRule_Unchecked"/>
                <ToggleButton x:Name="BtnElec003" Content="ELEC-003"
                              Style="{StaticResource FilterBtnStyle}"
                              Tag="ELEC-003"
                              Foreground="#FAB387" BorderBrush="#FAB387"
                              Checked="BtnRule_Checked"
                              Unchecked="BtnRule_Unchecked"/>
                <ToggleButton x:Name="BtnElec004" Content="ELEC-004"
                              Style="{StaticResource FilterBtnStyle}"
                              Tag="ELEC-004"
                              Foreground="#F38BA8" BorderBrush="#F38BA8"
                              Checked="BtnRule_Checked"
                              Unchecked="BtnRule_Unchecked"/>
            </WrapPanel>
        </Border>

        <!-- TreeView violations -->
        <TreeView x:Name="TreeViolations"
                  Grid.Row="3"
                  Background="#1E1E2E"
                  BorderThickness="0"
                  Padding="4,4,4,4"
                  VirtualizingPanel.IsVirtualizing="True">
            <TreeView.Resources>
                <!-- Style TreeViewItem niveau -->
                <Style TargetType="TreeViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#CDD6F4"/>
                    <Setter Property="IsExpanded" Value="True"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#313244"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2A2A3E"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TreeView.Resources>
        </TreeView>
    </Grid>
</Page>
